package day8;

public class Task1_Arrays {
	public static void main(String[] args) {
		int arr[] = {1,2,5,7,3,4,9,10,6} ;
		int sort[] = new int[arr.length];
		
 		
		for (int i=0 ; i<arr.length; i++) {
			for (int j= i+1 ; j<arr.length ; j++) {
				if (arr[i] < arr[j]) {
					sort[i] = arr[i];
				}
			}
		}
		
		for(int n : sort) {
			System.out.print(n + " ");
		}
	}
}
